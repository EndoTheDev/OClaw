{
  "provider": {
    "active": "ollama",
    "ollama": {
      "host": "http://localhost:11434"
    },
    "openai": {
      "host": "https://api.openai.com/v1",
      "api_key": "your_openai_api_key"
    },
    "anthropic": {
      "host": "https://api.anthropic.com/v1",
      "api_key": "your_anthropic_api_key"
    },
    "model": "glm-5:cloud"
  },
  "agent": {
    "max_iterations": 5
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "worker": {
    "num_processes": 4,
    "timeout": 300
  }
}
