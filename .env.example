# OClaw Configuration
# Copy this file to .env and customize as needed

# Ollama Settings
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=kimi-k2.5:cloud

# Agent Settings
MAX_ITERATIONS=5

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Worker Settings
NUM_WORKERS=4
WORKER_TIMEOUT=300
