# OClaw Configuration
# Copy this file to .env and customize as needed

# Provider Selection
PROVIDER_ACTIVE=ollama

# Provider Settings
PROVIDER_OLLAMA_HOST=http://localhost:11434
PROVIDER_MODEL=kimi-glm-5:cloud
PROVIDER_OPENAI_HOST=https://api.openai.com/v1
PROVIDER_OPENAI_API_KEY=your_openai_api_key
PROVIDER_ANTHROPIC_HOST=https://api.anthropic.com/v1
PROVIDER_ANTHROPIC_API_KEY=your_anthropic_api_key

# Agent Settings
AGENT_MAX_ITERATIONS=5

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Worker Settings
WORKER_NUM_PROCESSES=4
WORKER_TIMEOUT=300
